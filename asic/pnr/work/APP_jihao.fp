#####################################################################
#  <Property>                                                       #
#     <obj_type name="inst_name" >                                  #
#       <prop name="name" type=type_name value=val />               #
#       <Attr name="name" type=type_name value=val />               #
#     </obj_type>                                                   #
#  </Property>                                                      #
#  where:                                                           #
#       type is data type: Box, String, Int, PTR, Loc, double, Bits #
#       obj_type are: inst, Design, instTerm, Bump, cell, net       #
#####################################################################
<Properties>
  <Design name="APP">
	<prop name="CUT_ROWS" type=Int value=0 />
	<prop name="flow_implementation_stage" type=String value="postroute" def=yes />
	<prop name="TDRCAppName" type=String value="OPT_LA:1 GPS_LA:2 prLA:3 NRImport:4 detailRouteOnly:5 " />
	<prop name="flow_timed_design_state" type=String value="postRoute" def=yes />
  </Design>
</Properties>

###########################################################$############################################################################################
#  GlobalNetConnection: <net_name> {-pin|-instanceBasename|-net} <base_name_pattern> -type {pgpin|net|tiehi|tielo} {-all|-module <name>|-region <box>} [-override] #
########################################################################################################################################################
GlobalNetConnection: VDD -pin VDD -instanceBasename * -type pgpin -all -override
GlobalNetConnection: VSS -pin VSS -instanceBasename * -type pgpin -all -override
GlobalNetConnection: VSS -pin GND -instanceBasename * -type pgpin -all -override
GlobalNetConnection: VDD_1 -pin VDD -net VDD_1 -singleInst APPchan1 -type net
GlobalNetConnection: VDD_2 -pin VDDH -net VDD_2 -singleInst APPchan1 -type net
GlobalNetConnection: VDDPST -pin vdda_2p5 -net VDDPST -singleInst BGR1 -type net

################################################################################
#  NetProperties: <net_name> [-special] [-def_prop {int|dbl|str} <value>]...   #
################################################################################
NetProperties: VDD -special -def_prop wire_group_widest_ring dbl 70.001000
NetProperties: VSS -special -def_prop wire_group_widest_ring dbl 70.001000
NetProperties: VDD_1 -special -def_prop wire_group_widest_ring dbl 40.007000

